{
    "compilerOptions": {
        "module": "NodeNext",
        "target": "ESNext",
        "lib": ["ESNext"],
        "moduleResolution": "NodeNext",
        "types": ["node", "mocha"],
        "rootDir": "src",
        "declarationDir": "lib/types",
        "esModuleInterop": true,
        "emitDeclarationOnly": true,
        "declaration": true,
        "noEmitOnError": true,
        "strict": true,
        "forceConsistentCasingInFileNames": true
    },
    "include": ["src"]
}
